<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Compose apps need AppCompat or DeviceDefault, NOT android:Theme.Material.
      android:Theme.Material.NoTitleBar conflicts with Material3 + edge-to-edge.
    -->
    <style name="Theme.NyxChat" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#05030E</item>
        <item name="android:statusBarColor">#05030E</item>
        <item name="android:navigationBarColor">#05030E</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="colorPrimary">#9D6FFF</item>
        <item name="colorPrimaryDark">#05030E</item>
        <item name="colorAccent">#C084FC</item>
    </style>
</resources>
