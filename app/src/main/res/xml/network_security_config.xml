<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Only allow cleartext (HTTP) traffic to localhost for development.
    All real API endpoints should use HTTPS.
    If your API provider only supports HTTP, add their domain explicitly.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext to localhost for local model testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
